    .service-detail-visual {
        width: 100%;
        max-width: 100%;
        height: auto;
        aspect-ratio: 610 / 490;
        align-self: center;
    }
    
    .service-detail-visual img {
        width: 72%;
        height: auto;
        left: 14%;
    }
    
    .service-specs-btn {
        width: 146px;
        height: 41px;
        font-size: 12px;
        top: 89%;
        left: 50%;
        transform: translateX(-50%);
    }
    
    .service-detail-carousel {
        width: 100%;
        max-width: 100%;
        height: auto;
        aspect-ratio: 610 / 584;
    }
    
    .service-vulture-drone {
        width: 75%;
        height: auto;
        left: 12.5%;
    }
    
    .service-skyguard-radar {
        width: 54%;
        height: 72%;
        top: 3%;
        left: 23%;
    }
    
    .service-detail-carousel .service-carousel-image {
        width: 84%;
        height: 66%;
        top: 5%;
        left: 8%;
    }
    
    .service-detail-skyguard .service-detail-carousel .service-carousel-image {
        width: 60%;
        height: 70%;
        top: 3%;
        left: 20%;
    }
    
    .service-visual-caption {
        font-size: 18px;
        top: 78%;
    }
    
    .service-visual-arrow {
        width: 40px;
        height: 40px;
        top: 84%;
    }
    
    .service-detail-carousel .service-specs-btn {
        top: 91%;
    }
    
    .service-tactical-title span {
        font-size: 34px;
    }
    
    .service-tactical-title small {
        font-size: 22px;
    }
    
    /* Footer - Mobile Small */
    footer {
        padding: 20px 32px 32px 32px;
        height: auto;
        min-height: 70px;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 8px;
        font-size: 0.65rem;
    }
    
    .footer-copyright {
        font-size: 0.65rem;
    }
    
    .footer-links {
        display: none;
    }
}


/* ============================================
   SPECS MODAL - RESPONSIVE
   ============================================ */

/* Tablet Landscape & Portrait */
@media (max-width: 1023px) and (min-width: 600px) {
    .specs-modal {
        padding: 16px;
    }
    
    .specs-modal-panel {
        width: min(90%, 640px);
        min-height: 420px;
        padding: 36px 32px;
    }
    
    .specs-modal-close {
        top: 16px;
        right: 20px;
        font-size: 38px;
    }
    
    .specs-modal-product {
        font-size: 19px;
    }
    
    .specs-modal-form {
        width: 100%;
        margin-top: 36px;
        gap: 22px;
    }
    
    .specs-modal-row {
        grid-template-columns: 105px minmax(0, 1fr);
        gap: 14px;
    }
    
    .specs-modal-label {
        font-size: 15px;
    }
    
    .specs-modal-input,
    .specs-modal-country-selector {
        height: 42px;
        font-size: 15px;
    }
    
    .specs-modal-phone {
        grid-template-columns: 108px minmax(0, 1fr);
    }
    
    .specs-modal-submit {
        width: 140px;
        height: 42px;
        font-size: 13px;
    }
}

/* Mobile - All Sizes */
@media (max-width: 599px) {
    .specs-modal {
        padding: 10px;
        align-items: flex-start;
        padding-top: 40px;
    }
    
    .specs-modal-panel {
        width: 100%;
        min-height: 0;
        max-height: 90vh;
        padding: 28px 18px 24px;
        overflow-y: auto;
    }
    
    .specs-modal-close {
        top: 12px;
        right: 12px;
        width: 36px;
        height: 36px;
        font-size: 40px;
        line-height: 28px;
    }
    
    .specs-modal-product {
        font-size: 18px;
        padding-right: 40px;
    }
    
    .specs-modal-form {
        width: 100%;
        margin-top: 28px;
        gap: 20px;
    }
    
    .specs-modal-row {
        grid-template-columns: 1fr;
        gap: 8px;
    }
    
    .specs-modal-label {
        font-size: 14px;
        text-align: left;
    }
    
    .specs-modal-input,
    .specs-modal-country-selector {
        height: 46px;
        font-size: 16px;
        border-radius: 2px;
    }
    
    .specs-modal-phone {
        grid-template-columns: 110px minmax(0, 1fr);
        gap: 0;
    }
    
    .specs-modal-country-selector {
        width: 110px;
        gap: 6px;
        padding: 0 10px;
    }
    
    .specs-modal-country-selector .fi {
        font-size: 20px;
        width: 24px;
        height: 18px;
    }
    
    .specs-modal-submit {
        width: 100%;
        height: 48px;
        font-size: 14px;
        margin-top: 8px;
    }
    
    /* Country Dropdown - Mobile Optimized */
    .country-dropdown {
        width: 100%;
        max-width: calc(100vw - 36px);
        left: 0;
    }
    
    .country-search-input {
        font-size: 15px;
        padding: 10px 12px;
        height: 44px;
    }
    
    .country-option {
        padding: 12px 14px;
        min-height: 50px;
    }
    
    .country-option .fi {
        width: 26px;
        height: 20px;
    }
    
    .country-code {
        font-size: 1rem;
        min-width: 60px;
    }
    
    .country-name {
        font-size: 0.9rem;
    }
}


/* ============================================
   CONTACT PAGE - RESPONSIVE
   ============================================ */

/* Tablet Landscape */
@media (max-width: 1023px) and (min-width: 768px) {
    .contact-form-container {
        gap: 18px;
    }
    
    .form-row {
        gap: 12px !important;
    }
    
    .form-label {
        width: 95px !important;
        font-size: 0.75rem !important;
    }
    
    .form-input,
    .form-input-phone {
        height: 42px;
        font-size: 15px;
    }
    
    .form-textarea {
        min-height: 120px;
        font-size: 15px;
    }
    
    .country-selector {
        width: 100px;
        height: 42px;
    }
    
    .submit-btn-rect {
        width: 100px;
        height: 42px;
        font-size: 14px;
    }
    
    .contact-card-overlay {
        padding: 20px 24px;
        bottom: 24px;
    }
    
    .contact-card-cta {
        font-size: 10px;
    }
    
    .contact-card-link {
        font-size: 14px;
        gap: 8px;
    }
    
    .contact-card-link svg {
        width: 18px;
        height: 18px;
    }
    
    .illustration-container {
        max-width: 520px;
    }
}

/* Tablet Portrait */
@media (max-width: 767px) and (min-width: 600px) {
    .contact-page-bg .main-content {
        flex-direction: column;
        height: auto;
        min-height: calc(100vh - 145px);
        overflow-y: auto;
    }
    
    .contact-page-bg .content-left {
        width: 100%;
        min-height: auto;
        padding: clamp(28px, 5vw, 40px);
        justify-content: flex-start;
    }
    
    .contact-page-bg .content-right {
        width: 100%;
        height: auto;
        min-height: 400px;
        padding: clamp(28px, 5vw, 40px);
    }
    
    .contact-form-container {
        gap: 18px;
        max-width: 560px;
        margin: 0 auto;
    }
    
    .form-row {
        gap: 12px !important;
    }
    
    .form-label {
        width: 90px !important;
        font-size: 0.75rem !important;
    }
    
    .form-input,
    .form-input-phone {
        height: 44px;
        font-size: 15px;
    }
    
    .form-textarea {
        min-height: 130px;
        font-size: 15px;
    }
    
    .country-selector {
        width: 98px;
        height: 44px;
    }
    
    .submit-btn-rect {
        width: 110px;
        height: 44px;
        font-size: 14px;
    }
    
    .illustration-container {
        max-width: 480px;
        margin: 0 auto;
    }
    
    .contact-card-overlay {
        position: relative;
        bottom: auto;
        left: auto;
        margin-top: 20px;
        padding: 22px 26px;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }
    
    .contact-card-cta {
        font-size: 10px;
    }
    
    .contact-card-link {
        font-size: 14px;
    }
}

/* Mobile - All Sizes */
@media (max-width: 599px) {
    .contact-page-bg .main-content {
        flex-direction: column;
        height: auto;
        min-height: auto;
        overflow-y: auto;
    }
    
    .contact-page-bg .content-left {
        width: 100%;
        min-height: auto;
        padding: 40px 32px;
        justify-content: flex-start;
        order: 1;
    }
    
    .contact-page-bg .content-right {
        width: 100%;
        height: auto;
        min-height: 380px;
        padding: 32px;
        order: 2;
    }
    
    .contact-form-container {
        gap: 18px;
        width: 100%;
        max-width: 100%;
    }
    
    .form-row {
        flex-direction: column !important;
        gap: 8px !important;
        align-items: flex-start !important;
    }
    
    .form-label {
        width: 100% !important;
        text-align: left !important;
        font-size: 0.7rem !important;
        letter-spacing: 0.08em !important;
    }
    
    .form-input,
    .form-input-phone {
        height: 46px;
        font-size: 16px;
        padding: 0 14px;
    }
    
    .form-textarea {
        min-height: 140px;
        font-size: 16px;
        padding: 14px;
    }
    
    .country-selector {
        width: 105px;
        height: 46px;
        padding: 0 10px;
    }
    
    .country-selector .fi {
        width: 24px;
        height: 18px;
    }
    
    .submit-row {
        margin-top: 12px;
    }
    
    .submit-btn-rect {
        width: 100%;
        max-width: 100%;
        height: 48px;
        font-size: 14px;
    }
    
    .illustration-container {
        width: 100%;
        max-width: 100%;
    }
    
    .illustration-container img {
        max-width: 100%;
        height: auto;
    }
    
    .contact-card-overlay {
        position: relative;
        bottom: auto;
        left: auto;
        width: 100%;
        margin-top: 24px;
        padding: 22px 24px;
        background: rgba(23, 23, 23, 0.85);
        backdrop-filter: blur(6px);
    }
    
    .contact-card-cta {
        font-size: 9px;
        margin-bottom: 10px;
        padding-bottom: 12px;
    }
    
    .contact-card-link {
        font-size: 13px;
        gap: 8px;
    }
    
    .contact-card-link svg {
        width: 18px;
        height: 18px;
    }
}

/* Mobile Small - Extra Optimizations */
@media (max-width: 479px) {
    .contact-page-bg .content-left {
        padding: 40px 32px;
    }
    
    .contact-page-bg .content-right {
        padding: 32px;
        min-height: 400px;
    }
    
    .contact-form-container {
        gap: 16px;
    }
    
    .form-label {
        font-size: 0.65rem !important;
    }
    
    .form-input,
    .form-input-phone,
    .form-textarea {
        font-size: 15px;
    }
    
    .country-selector {
        width: 100px;
    }
    
    .contact-card-overlay {
        padding: 20px 24px;
        margin-top: 28px;
    }
    
    .contact-card-cta {
        font-size: 8px;
    }
    
    .contact-card-link {
        font-size: 12px;
    }
}


/* ============================================
   TOUCH-FRIENDLY ENHANCEMENTS
   ============================================ */
@media (max-width: 1023px) {
    /* زيادة حجم الأزرار للمس الأسهل */
    button,
    .primary-btn,
    .secondary-btn,
    .service-secondary-btn,
    .submit-btn-rect,
    a[role="button"] {
        min-height: 44px;
        max-width: 50%;
        touch-action: manipulation;
        -webkit-tap-highlight-color: rgba(227, 6, 19, 0.2);
    }
    
    /* زر اتصل بنا في الهيدر - يبقى بعرضه الكامل */
    .nav-cta-btn {
        max-width: 194px;
        width: 194px;
    }
    
    /* تحسين النماذج للموبايل */
    input,
    textarea,
    select {
        font-size: 16px !important; /* منع Auto-zoom في iOS */
        touch-action: manipulation;
    }
    
    /* تحسين الروابط */
    a {
        touch-action: manipulation;
        -webkit-tap-highlight-color: rgba(227, 6, 19, 0.15);
    }
    
    /* تحسين Solutions Map للمس */
    .solution-panel {
        pointer-events: all;
        cursor: pointer;
    }
    
    .solutions-wireframe-svg a {
        touch-action: manipulation;
    }
    
    /* مساحة أكبر للأسهم */
    .service-visual-arrow {
        min-width: 44px;
        min-height: 44px;
        touch-action: manipulation;
    }
    
    /* Modal Close Button */
    .specs-modal-close {
        min-width: 44px;
        min-height: 44px;
        touch-action: manipulation;
    }
    
    /* Country Selector */
    .country-selector,
    .specs-modal-country-selector {
        min-height: 44px;
        touch-action: manipulation;
    }
    
    .country-option {
        min-height: 48px;
        touch-action: manipulation;
    }
}

/* ============================================
   PERFORMANCE OPTIMIZATIONS
   ============================================ */
@media (max-width: 1023px) {
    /* تقليل Backdrop Filter للأداء */
    .contact-card-overlay {
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }
    
    /* تحسين الـ Transforms */
    .service-carousel-image,
    .service-vulture-drone {
        will-change: opacity, transform;
    }
    
    /* تحسين Scrolling */
    .main-content,
    .specs-modal-panel,
    .country-list {
        -webkit-overflow-scrolling: touch;
        overscroll-behavior: contain;
    }
}

/* ============================================
   LANDSCAPE MODE FIXES (للموبايل في الوضع الأفقي)
   ============================================ */
@media (max-width: 900px) and (max-height: 500px) and (orientation: landscape) {
    header {
        height: 60px;
        padding: 0 16px;
    }
    
    .logo-container img {
        width: 140px;
    }
    
    .nav-cta-btn {
        width: 130px;
        min-height: 38px;
        font-size: 11px;
    }
    
    .main-content {
        height: calc(100vh - 120px);
        flex-direction: row;
        overflow-y: auto;
    }
    
    .content-left {
        width: 50%;
        min-height: 100%;
        padding: 20px 16px;
    }
    
    .content-right {
        width: 50%;
        height: 100%;
        min-height: auto;
    }
    
    h1.page-title {
        font-size: clamp(20px, 5vw, 28px);
        margin-bottom: 12px;
    }
    
    .page-description {
        font-size: clamp(12px, 2.5vw, 14px);
        line-height: 1.5;
    }
    
    .primary-btn {
        margin-top: 20px;
        min-height: 40px;
    }
    
    footer {
        height: 60px;
        padding: 10px 16px;
        font-size: 0.6rem;
    }
}


/* ============================================
   SOLUTIONS PAGE - ADVANCED RESPONSIVE
   ============================================ */

/* Tablet Portrait to Mobile */
@media (max-width: 767px) {
    .solutions-wireframe-svg {
        touch-action: manipulation;
    }
    
    .solution-svg-labels text {
        pointer-events: none;
        user-select: none;
    }
    
    /* تحسين النصوص في الخريطة */
    .solution-svg-labels {
        font-size: clamp(16px, 18px, 22px);
    }
    
    .solution-svg-label tspan {
        dominant-baseline: middle;
    }
    
    /* تحسين التفاعل مع المناطق */
    .solution-panel {
        transition: fill 200ms ease, opacity 200ms ease;
    }
    
    .solution-panels a:active .solution-panel {
        fill: rgba(139, 139, 139, 0.85);
        opacity: 0.95;
    }
    
    /* Solutions Footer Instruction */
    .solutions-footer-instruction {
        font-size: 0.65rem;
        bottom: 16px;
        letter-spacing: 0.15em;
        text-align: center;
        padding: 0 20px;
    }
}

@media (max-width: 479px) {
    .solutions-reference {
        padding: 16px 12px;
        gap: 14px;
    }
    
    .solutions-title {
        font-size: 22px;
        line-height: 1.3;
    }
    
    .solution-svg-labels {
        font-size: clamp(14px, 4vw, 18px);
    }
    
    .solutions-footer-instruction {
        font-size: 0.6rem;
        bottom: 12px;
    }
}

/* ============================================
   SERVICE DETAIL PAGES - ADVANCED RESPONSIVE
   ============================================ */

/* Tablet Portrait */
@media (max-width: 767px) and (min-width: 600px) {
    
    .service-detail-vulture_uavs .service-detail-heading,
    .service-detail-skyguard .service-detail-heading {
        width: auto;
        height: auto;
        margin-bottom: 12px;
    }
    
    .service-vulture-title {
        font-size: 36px !important;
        line-height: 0.95 !important;
    }
    
    .service-vulture-title small {
        font-size: 18px !important;
        margin-top: 8px;
    }
    
    .service-detail-skyguard .service-detail-heading h1 {
        font-size: 28px;
    }
    
    .service-tactical-title span {
        font-size: 34px;
    }
    
    .service-tactical-title small {
        font-size: 22px;
    }
}

/* Mobile - All Service Details */
@media (max-width: 599px) {
    .service-detail-page .main-content {
        height: auto;
        min-height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
    }
    
    .service-detail-page::-webkit-scrollbar {
        display: none;
    }
    
    .service-detail-page {
        scrollbar-width: none;
    }
    
    .service-detail {
        gap: 22px;
        padding: 24px 48px;
    }
    
    .service-detail-copy {
        width: 100%;
    }
    
    .service-detail-heading {
        display: flex;
        justify-content: flex-start;
        align-items: center;
    }
    
    .service-detail-logo {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
    
    .service-detail-vulture_uavs .service-detail-heading,
    .service-detail-skyguard .service-detail-heading,
    .service-detail-tactical_data_link .service-detail-heading {
        width: auto;
        height: auto;
        max-width: 50vw;
        justify-content: flex-start;
    }
    
    .service-detail-description {
        margin-top: 20px;
        text-align: left;
    }
    
    .service-detail-vulture_uavs .service-detail-description,
    .service-detail-skyguard .service-detail-description,
    .service-detail-tactical_data_link .service-detail-description {
        margin-top: 20px;
    }
    
    /* Visual Container Adjustments */
    .service-detail-visual,
    .service-detail-carousel {
        position: relative;
        margin: 0 auto;
    }
    
    .service-visual-caption {
        position: absolute;
        width: 100%;
        text-align: center;
        font-size: clamp(14px, 3.5vw, 18px);
    }
    
    .service-visual-arrow-prev {
        left: 8px;
    }
    
    .service-visual-arrow-next {
        right: 8px;
    }
    
    .service-specs-btn {
        position: absolute;
        border: 1px solid rgba(156, 163, 175, 0.55);
        background: rgba(255, 255, 255, 0.04);
        transition: all var(--transition-fast);
    }
    
    .service-specs-btn:active {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(197, 192, 192, 0.8);
    }
}

/* Mobile Small - Extra Fine Tuning */
@media (max-width: 479px) {
    .service-detail {
        padding: 22px 14px;
        gap: 18px;
    }
    
    .service-detail-heading h1 {
        font-size: 26px;
    }
    
    .service-detail-description {
        font-size: 20px;
        line-height: 1.6;
    }
    
    .service-secondary-btn {
        width: 100%;
        margin-top: 24px;
    }
    
    .service-specs-btn {
        width: 120px;
        height: 38px;
        font-size: 10px;
    }
    
    .service-visual-caption {
        font-size: clamp(13px, 3.8vw, 16px);
    }
    
    .service-visual-arrow {
        width: 34px;
        height: 34px;
        font-size: 28px;
    }
}


/* ============================================
   VIEWPORT META FIXES & ORIENTATION HANDLING
   ============================================ */

/* منع Zoom غير المرغوب في iOS */
@media (max-width: 1023px) {
    input[type="text"],
    input[type="email"],
    input[type="tel"],
    textarea,
    select {
        font-size: 16px !important;
    }
}

/* تحسين عرض الخطوط على الشاشات الصغيرة */
@media (max-width: 767px) {
    body {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
}

/* ============================================
   SAFE AREAS (للهواتف مع Notch)
   ============================================ */
@supports (padding: max(0px)) {
    @media (max-width: 767px) {
        header {
            padding-left: max(16px, env(safe-area-inset-left));
            padding-right: max(16px, env(safe-area-inset-right));
            padding-top: env(safe-area-inset-top);
        }
        
        footer {
            padding-left: max(16px, env(safe-area-inset-left));
            padding-right: max(16px, env(safe-area-inset-right));
            padding-bottom: max(10px, env(safe-area-inset-bottom));
        }
        
        .content-left,
        .content-right {
            padding-left: max(16px, env(safe-area-inset-left));
            padding-right: max(16px, env(safe-area-inset-right));
        }
        
        .specs-modal {
            padding-left: max(10px, env(safe-area-inset-left));
            padding-right: max(10px, env(safe-area-inset-right));
            padding-bottom: max(10px, env(safe-area-inset-bottom));
        }
    }
}

/* ============================================
   ANIMATION PERFORMANCE
   ============================================ */
@media (max-width: 1023px) {
    /* تقليل الحركات للأجهزة الضعيفة */
    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
    }
    
    /* تحسين GPU Acceleration */
    .service-carousel-image,
    .service-vulture-drone,
    .service-skyguard-radar,
    .solution-panel,
    .contact-card-overlay {
        transform: translateZ(0);
        backface-visibility: hidden;
        perspective: 1000px;
    }
}

/* ============================================
   UTILITIES - RESPONSIVE HELPERS
   ============================================ */

/* Hide on Mobile */
@media (max-width: 599px) {
    .hide-on-mobile {
        display: none !important;
    }
}

/* Hide on Tablet */
@media (max-width: 1023px) and (min-width: 600px) {
    .hide-on-tablet {
        display: none !important;
    }
}

/* Show only on Mobile */
@media (min-width: 600px) {
    .show-only-mobile {
        display: none !important;
    }
}

/* ============================================
   FALLBACK SVG CONTAINER - RESPONSIVE
   ============================================ */
@media (max-width: 1023px) {
    .fallback-svg-container {
        padding: 20px;
    }
    
    .fallback-svg-container svg {
        max-width: 92%;
        max-height: 92%;
    }
    
    .fallback-path {
        stroke-width: 1.5;
        touch-action: manipulation;
    }
    
    .fallback-text {
        font-size: 10px;
    }
}

@media (max-width: 599px) {
    .fallback-svg-container {
        padding: 12px;
    }
    
    .fallback-svg-container svg {
        max-width: 96%;
        max-height: 96%;
    }
    
    .fallback-text {
        font-size: 9px;
    }
}

/* ============================================
   MODEL-VIEWER RESPONSIVE (3D Models)
   ============================================ */
@media (max-width: 1023px) {
    model-viewer {
        width: 100%;
        height: 100%;
        touch-action: pan-y;
    }
    
    .hotspot {
        width: 18px;
        height: 18px;
        border-width: 2px;
        touch-action: manipulation;
    }
    
    .hotspot-annotation {
        font-size: 0.65rem;
        padding: 5px 10px;
        left: 26px;
    }
}

@media (max-width: 599px) {
    .hotspot {
        width: 16px;
        height: 16px;
        border-width: 1.5px;
    }
    
    .hotspot-annotation {
        font-size: 0.6rem;
        padding: 4px 8px;
        left: 22px;
        white-space: normal;
        max-width: 180px;
    }
}

/* ============================================
   IMAGE LOADING OPTIMIZATION
   ============================================ */
@media (max-width: 1023px) {
    img {
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
    }
    
    img[loading="lazy"] {
        content-visibility: auto;
    }
}

/* ============================================
   SCROLLBAR STYLING - MOBILE
   ============================================ */
@media (max-width: 1023px) {
    /* إخفاء scrollbar على صفحات الخدمات */
    .service-detail-page,
    .service-detail-page .main-content,
    .service-detail-page body {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    
    .service-detail-page::-webkit-scrollbar,
    .service-detail-page .main-content::-webkit-scrollbar,
    .service-detail-page body::-webkit-scrollbar {
        display: none;
        width: 0;
        height: 0;
    }
    
    /* Webkit browsers */
    ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    
    ::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.2);
    }
    
    ::-webkit-scrollbar-thumb {
        background: rgba(156, 163, 175, 0.4);
        border-radius: 3px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: rgba(156, 163, 175, 0.6);
    }
}

/* ============================================
   FOCUS STATES - ACCESSIBILITY
   ============================================ */
@media (max-width: 1023px) {
    /* تحسين Focus للوصول بالكيبورد */
    a:focus-visible,
    button:focus-visible,
    input:focus-visible,
    textarea:focus-visible,
    select:focus-visible {
        outline: 2px solid var(--accent-red);
        outline-offset: 2px;
    }
    
    /* إخفاء outline عند اللمس */
    a:focus:not(:focus-visible),
    button:focus:not(:focus-visible),
    input:focus:not(:focus-visible) {
        outline: none;
    }
}


/* ============================================
   HIGH DPI / RETINA DISPLAYS
   ============================================ */
@media (max-width: 1023px) and (-webkit-min-device-pixel-ratio: 2),
       (max-width: 1023px) and (min-resolution: 192dpi) {
    /* تحسين الخطوط للشاشات عالية الدقة */
    body {
        -webkit-font-smoothing: subpixel-antialiased;
        -moz-osx-font-smoothing: auto;
    }
    
    /* تحسين الحدود والخطوط */
    .solution-panel,
    .solutions-wire-lines,
    .wireframe-line {
        stroke-width: 3.75px;
    }
    
    input,
    textarea,
    select {
        border-width: 0.5px;
    }
}

/* ============================================
   PRINT STYLES - RESPONSIVE
   ============================================ */
@media print {
    html, body {
        overflow: visible !important;
    }
    
    header,
    footer,
    .nav-cta-btn,
    .primary-btn,
    .secondary-btn,
    .specs-modal,
    .contact-card-overlay {
        display: none !important;
    }
    
    .main-content {
        height: auto !important;
        overflow: visible !important;
    }
    
    .content-left,
    .content-right {
        width: 100% !important;
        height: auto !important;
        page-break-inside: avoid;
    }
}

/* ============================================
   DARK MODE ADJUSTMENTS (للأجهزة التي تفضل Dark Mode)
   ============================================ */
@media (prefers-color-scheme: dark) {
    /* الموقع already dark، لكن نحسن التباين */
    @media (max-width: 1023px) {
        :root {
            --text-muted: #a8a8a8;
            --line-soft: rgba(255, 255, 255, 0.14);
        }
        
        .form-input,
        .form-textarea,
        .specs-modal-input {
            background-color: #151515;
        }
        
        .country-dropdown {
            background-color: #151515;
        }
    }
}

/* ============================================
   REDUCED DATA MODE (للاتصال البطيء)
   ============================================ */
@media (prefers-reduced-data: reduce) {
    /* تقليل الصور الكبيرة */
    .home-page-bg {
        background-image: none;
        background-color: var(--bg-primary);
    }
    
    /* إيقاف الـ Backdrop Filters */
    .contact-card-overlay {
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
        background: rgba(23, 23, 23, 0.95);
    }
    
    /* تقليل الظلال */
    .country-dropdown,
    .specs-modal-panel {
        box-shadow: none;
        border: 2px solid var(--line-strong);
    }
}

/* ============================================
   CONTRAST ADJUSTMENTS (للوصول)
   ============================================ */
@media (prefers-contrast: high) {
    @media (max-width: 1023px) {
        :root {
            --text-muted: #b8b8b8;
            --line-soft: rgba(255, 255, 255, 0.2);
            --line-strong: rgba(255, 255, 255, 0.35);
        }
        
        .primary-btn,
        .nav-cta-btn,
        .service-secondary-btn {
            border-width: 2px;
        }
        
        input,
        textarea,
        select {
            border-width: 2px;
        }
        
        .solution-panel:hover {
            fill: rgba(139, 139, 139, 1);
        }
    }
}


/* ============================================
   SPECIFIC FIXES & EDGE CASES
   ============================================ */

/* Fix: iPhone X+ Notch في Landscape */
@media (max-width: 900px) and (orientation: landscape) {
    @supports (padding: max(0px)) {
        .viewport-page {
            padding-left: env(safe-area-inset-left);
            padding-right: env(safe-area-inset-right);
        }
    }
}

/* Fix: Android Chrome Address Bar Jump */
@media (max-width: 767px) {
    .viewport-page {
        min-height: 100vh;
        min-height: -webkit-fill-available;
    }
    
    .main-content {
        min-height: calc(100vh - 140px);
        min-height: calc(-webkit-fill-available - 140px);
    }
}

/* Fix: iPad Pro في Portrait Mode */
@media (min-width: 768px) and (max-width: 1024px) and (orientation: portrait) {
    .solutions-map {
        width: clamp(600px, 75vw, 760px);
    }
    
    .service-detail-visual,
    .service-detail-carousel {
        max-width: 640px;
    }
}

/* Fix: iPad Pro في Landscape Mode */
@media (min-width: 1024px) and (max-width: 1366px) and (orientation: landscape) {
    .content-left {
        width: 48%;
    }
    
    .content-right {
        width: 52%;
    }
}

/* Fix: Samsung Fold (Narrow Screen) */
@media (max-width: 360px) {
    .logo-container img {
        width: 140px;
    }
    
    .nav-cta-btn {
        width: 120px;
        font-size: 10px;
        padding: 6px;
    }
    
    h1.page-title {
        font-size: 20px;
    }
    
    .page-description {
        font-size: 12px;
    }
    
    .primary-btn {
        width: 130px;
        min-height: 42px;
        font-size: 12px;
    }
    
    .solutions-title {
        font-size: 20px;
    }
    
    .solution-svg-labels {
        font-size: 14px;
    }
}

/* Fix:Overflow Hidden على الموبايل */
@media (max-width: 767px) {
    body {
        position: relative;
        overflow-x: hidden;
    }
    
    .viewport-page {
        position: relative;
        overflow-x: hidden;
        width: 100%;
        max-width: 100vw;
    }
    
    * {
        max-width: 100%;
    }
    
    img,
    svg {
        max-width: 100%;
        height: auto;
    }
}

/* Fix: Form Input Zoom في iOS Safari */
@media (max-width: 767px) {
    @supports (-webkit-touch-callout: none) {
        input,
        textarea,
        select {
            font-size: 16px !important;
        }
    }
}

/* Fix: Sticky Hover States على Touch Devices */
@media (hover: none) and (pointer: coarse) {
    .primary-btn:hover,
    .nav-cta-btn:hover,
    .solution-panel:hover,
    .contact-card-link:hover {
        /* إلغاء hover states على الأجهزة اللمسية */
        color: inherit;
        background: inherit;
        border-color: inherit;
        transform: none;
    }
    
    /* استخدام active بدلاً من hover */
    .primary-btn:active,
    .nav-cta-btn:active {
        background-color: var(--btn-hover-bg-soft);
        border-color: var(--system-hover-stroke);
    }
    
    .solution-panels a:active .solution-panel {
        fill: rgba(139, 139, 139, 0.96);
    }
    
    .contact-card-link:active {
        color: rgba(255, 255, 255, 1);
        transform: translateX(2px);
    }
}

/* ============================================
   LOADING STATES & SKELETON SCREENS
   ============================================ */
@media (max-width: 1023px) {
    /* Smooth loading للصور */
    img {
        opacity: 1;
        transition: opacity 0.3s ease;
    }
    
    img[loading="lazy"]:not([src]) {
        opacity: 0;
    }
    
    /* Placeholder للمحتوى أثناء التحميل */
    .service-carousel-image[src=""],
    .service-vulture-drone[src=""] {
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.02) 0%,
            rgba(255, 255, 255, 0.05) 50%,
            rgba(255, 255, 255, 0.02) 100%
        );
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
    }
    
    @keyframes shimmer {
        0% {
            background-position: -200% 0;
        }
        100% {
            background-position: 200% 0;
        }
    }
}

/* ============================================
   FINAL POLISH & MICRO-INTERACTIONS
   ============================================ */
@media (max-width: 1023px) {
    /* Smooth Scroll Behavior */
    html {
        scroll-behavior: smooth;
    }
    
    /* Better Selection Color */
    ::selection {
        background-color: rgba(227, 6, 19, 0.3);
        color: var(--text-white);
    }
    
    ::-moz-selection {
        background-color: rgba(227, 6, 19, 0.3);
        color: var(--text-white);
    }
    
    /* Active States Enhancement */
    button:active,
    .primary-btn:active,
    .submit-btn-rect:active {
        transform: scale(0.98);
        transition: transform 0.1s ease;
    }
    
    /* Input Focus Enhancement */
    input:focus,
    textarea:focus {
        border-color: var(--accent-red);
        box-shadow: 0 0 0 3px rgba(227, 6, 19, 0.1);
    }
}

/* ============================================
   END OF RESPONSIVE SYSTEM
   ============================================ */


/* ============================================
   MOBILE NAVIGATION BUTTONS - CONTEXT BASED
   ============================================ */

/* إخفاء زر Mobile Navigation على Desktop */
.mobile-nav-btn {
    display: none;
}

/* إظهار زر Navigation على Solutions و Contact فقط على الموبايل */
@media (max-width: 599px) {
    .mobile-nav-btn {
        width: 100%;
        max-width: 376px;
        min-height: 54px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        color: var(--text-white);
        font-family: 'Cairo', sans-serif;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: 0.05em;
        border-top: 1px solid var(--btn-border);
        border-bottom: 1px solid var(--btn-border);
        border-left: none;
        border-right: none;
        background-color: var(--transparent);
        transition: all var(--transition-fast);
        text-transform: uppercase;
        margin-bottom: 24px;
        touch-action: manipulation;
    }
    
    .mobile-nav-btn:hover,
    .mobile-nav-btn:active {
        color: var(--text-white);
        border-top-color: var(--system-hover-stroke);
        border-bottom-color: var(--system-hover-stroke);
        background-color: var(--btn-hover-bg-soft);
    }
    
    /* تعديل Footer للموبايل على صفحات Solutions و Contact */
    .solutions-page-bg footer,
    .contact-page-bg footer {
        flex-direction: column;
        align-items: flex-start;
    }
}

/* Mobile Large - زر أكبر قليلاً */
@media (max-width: 599px) and (min-width: 480px) {
    .mobile-nav-btn {
        max-width: 380px;
        min-height: 52px;
        font-size: 15px;
    }
}
