    .service-secondary-btn {
        margin-top: clamp(32px, 5vh, 56px);
    }
    
    .service-detail-visual {
        width: 100%;
        max-width: 560px;
        height: auto;
        aspect-ratio: 610 / 490;
        align-self: center;
    }
    
    .service-detail-visual img {
        width: 75%;
        height: auto;
        left: 12.5%;
    }
    
    .service-specs-btn {
        top: 88%;
        left: 50%;
        transform: translateX(-50%);
    }
    
    /* Vulture Service Details - Tablet */
